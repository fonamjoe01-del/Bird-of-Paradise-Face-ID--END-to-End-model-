<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Papua New Guinea National Emblem</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="emblem">

    <!-- Bird of Paradise -->
    <div class="bird">
        <img src="bird-of-paradise.png" alt="Raggiana Bird-of-Paradise">
    </div>

    <!-- Spear -->
    <div class="spear"></div>

    <!-- Kundu Drum -->
    <div class="drum">
        <div class="top"></div>
        <div class="body"></div>
        <div class="bottom"></div>
    </div>

    <h1>PAPUA NEW GUINEA</h1>
    <p>National Emblem</p>

</div>

</body>
</html>
